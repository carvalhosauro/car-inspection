{
  "cli": {
    "version": ">= 16.0.0",
    "appVersionSource": "local"
  },
  "build": {
    "preview": {
      "distribution": "internal",
      "credentialsSource": "local",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://vistoriaapi-production.up.railway.app"
      }
    },
    "preview-local": {
      "extends": "preview",
      "env": {
        "EXPO_PUBLIC_API_URL": "https://vistoriaapi-production.up.railway.app",
        "ORG_GRADLE_PROJECT_reactNativeArchitectures": "arm64-v8a",
        "CMAKE_BUILD_PARALLEL_LEVEL": "2",
        "GRADLE_OPTS": "-Dorg.gradle.workers.max=1 -Dorg.gradle.parallel=false -Dorg.gradle.jvmargs=-Xmx2g -Dorg.gradle.daemon=false"
      }
    },
    "production": {
      "credentialsSource": "local",
      "android": {
        "buildType": "app-bundle"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://vistoriaapi-production.up.railway.app"
      }
    }
  }
}
