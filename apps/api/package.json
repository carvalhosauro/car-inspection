    "@google-cloud/vision": "^4.3.0",
    "@supabase/supabase-js": "^2.45.0",
    "@vistoria/contracts": "workspace:*",
    "@vistoria/db": "workspace:*",
    "argon2": "^0.41.0",
    "blockhash-core": "^0.1.0",
    "drizzle-orm": "^0.36.0",
    "fast-jwt": "^4.0.0",
    "fastify": "^5.0.0",
    "fastify-plugin": "^5.0.0",
    "fastify-type-provider-zod": "^4.0.0",
    "sharp": "^0.33.0",
    "ulid": "^2.3.0",
    "zod": "^3.23.0"
