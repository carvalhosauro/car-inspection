# --- Banco (Settings → Database → Connection string → URI, modo Session) ---
DATABASE_URL=postgresql://postgres.mhsllxllzbockkyqhibb:<DB_PASSWORD>@aws-0-us-east-1.pooler.supabase.com:5432/postgres

# --- Storage Supabase ---
STORAGE_DRIVER=supabase
SUPABASE_URL=https://mhsllxllzbockkyqhibb.supabase.co
SUPABASE_SERVICE_KEY=<SERVICE_ROLE_KEY>
SUPABASE_STORAGE_BUCKET=vistoria-photos

# --- API ---
JWT_SECRET=<gere-um-secret-forte>
JWT_REFRESH_SECRET=<gere-outro-secret-forte>
PORT=3333
API_PUBLIC_URL=http://localhost:3333

# --- Opcional: Google Vision (OCR/fotos) ---
# GOOGLE_APPLICATION_CREDENTIALS=./apps/api/gcp-vision.json

# --- Clientes ---
NEXT_PUBLIC_API_URL=http://localhost:3333
