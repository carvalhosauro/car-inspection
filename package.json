{
  "name": "vistoria",
  "private": true,
  "packageManager": "pnpm@9.12.0",
  "engines": { "node": ">=20" },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "db:migrate": "pnpm --filter @vistoria/db db:migrate",
    "db:seed": "pnpm --filter @vistoria/db db:seed",
    "db:setup": "bash scripts/db-setup.sh",
    "dev:api": "bash scripts/dev.sh"
  },
  "devDependencies": {
    "turbo": "^2.1.0",
    "typescript": "^5.6.0"
  }
}
