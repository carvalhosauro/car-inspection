{
  "name": "vistoria",
  "private": true,
  "packageManager": "pnpm@9.12.0",
  "engines": { "node": ">=20" },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "build:mobile:apk": "pnpm --filter @vistoria/mobile build:apk"
  },
  "devDependencies": {
    "turbo": "^2.1.0",
    "typescript": "^5.6.0"
  },
  "pnpm": {
    "overrides": {
      "react": "19.2.7",
      "react-dom": "19.2.7",
      "@types/react": "19.2.17",
      "@types/react-dom": "19.2.3"
    },
    "packageExtensions": {
      "lucide-react": {
        "peerDependencies": { "@types/react": "*" }
      }
    }
  }
}
